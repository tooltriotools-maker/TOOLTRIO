          <Link href="/commodities" className="text-sm text-yellow-600 hover:text-yellow-700 flex items-center gap-1 font-bold">
            Browse all 60 <ChevronRight className="w-4 h-4" />
          </Link>
        </div>
        {/* Live gold karat teaser */}
        <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-3">
          {[
            { name: 'Gold Price Calculator', desc: '24K/22K/18K live karat prices', href: '/commodities/gold-price-calculator', icon: '🥇', badge: 'LIVE' },
            { name: 'Silver Calculator',      desc: '999/925/900 purity live price', href: '/commodities/silver-price-calculator', icon: '🥈', badge: 'LIVE' },
            { name: 'Crude Oil (WTI)',         desc: 'Live WTI price per barrel',     href: '/commodities/crude-oil-calculator',    icon: '🛢️', badge: null  },
            { name: 'Brent Crude Oil',         desc: 'Global benchmark live price',   href: '/commodities/brent-crude-calculator',  icon: '⛽', badge: null  },
            { name: 'Natural Gas',             desc: 'Henry Hub live price/MMBtu',    href: '/commodities/natural-gas-calculator',  icon: '🔥', badge: null  },
            { name: 'Platinum Price',          desc: 'Live platinum per gram & oz',   href: '/commodities/platinum-price-calculator', icon: '💎', badge: null },
            { name: 'Gold Loan Calculator',    desc: 'Loan against gold at live price', href: '/commodities/gold-loan-calculator', icon: '🏦', badge: 'Popular' },
            { name: 'Metals P&amp;L',            desc: 'Buy/sell profit on metals',      href: '/commodities/precious-metals-profit-calculator', icon: '💰', badge: null },
            { name: 'Palladium Price',         desc: 'Live palladium spot price',     href: '/commodities/palladium-price-calculator', icon: '⚗️', badge: null },
            { name: 'Portfolio Tracker',       desc: 'Track all commodity holdings',  href: '/commodities/commodity-portfolio-tracker', icon: '🗂️', badge: null },
          ].map(calc => (
            <Link key={calc.href} href={calc.href}
              className="group relative p-4 rounded-2xl bg-white border border-gray-100 shadow-card hover:border-yellow-300 hover:shadow-card-hover transition-all duration-200">
              {calc.badge && (
                <span className={`absolute top-2 right-2 text-[10px] font-bold px-1.5 py-0.5 rounded-full border ${calc.badge === 'LIVE' ? 'bg-green-100 text-green-700 border-green-200' : 'bg-yellow-100 text-yellow-700 border-yellow-200'}`}>{calc.badge}</span>
              )}
              <div className="text-2xl mb-2">{calc.icon}</div>
              <p className="font-bold text-gray-900 text-sm group-hover:text-yellow-700 transition-colors leading-tight">{calc.name}</p>
              <p className="text-xs text-gray-400 mt-0.5 leading-relaxed">{calc.desc}</p>
            </Link>
          ))}
        </div>
      </section>

      {/* ── Blog Section ── */}
      <section className="max-w-6xl mx-auto px-4 mb-12" aria-label="Blog articles">
        <div className="flex items-center justify-between mb-5">
