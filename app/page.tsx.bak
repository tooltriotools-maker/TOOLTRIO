              <h3 className="font-black text-gray-900 text-sm leading-tight group-hover:text-blue-700 transition-colors mb-3">{blog.title}</h3>
              <span className="text-xs text-blue-600 font-semibold flex items-center gap-1 group-hover:gap-2 transition-all">Read guide <ArrowRight className="w-3 h-3" /></span>
            </Link>
          ))}
        </div>
      </section>

      {/* ── About Section ── */
      <section className="max-w-5xl mx-auto px-4 mb-10">
        <div className="bg-gradient-to-br from-green-50 to-white rounded-3xl border border-green-100 p-8">
          <h2 className="text-2xl font-black text-gray-900 mb-2">
            The Most Comprehensive Free Calculator Platform — <span className="gradient-text">392 Tools</span>
          </h2>
          <p className="text-gray-500 mb-6 text-base">No signup · No ads · No data stored · Works on every device</p>

          {/* Category counts */}
          <div className="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
            {[
              { icon: '💰', label: 'Finance Calculators', count: 151, href: '/calculators/finance', color: 'text-green-700', bg: 'bg-green-100 border-green-200', desc: '401k, SIP, EMI, Mortgage, FIRE & more' },
              { icon: '❤️', label: 'Health Calculators', count: 121, href: '/calculators/health', color: 'text-red-700', bg: 'bg-red-100 border-red-200', desc: 'BMI, Calories, BMR, Heart Risk & more' },
              { icon: '⚡', label: 'Developer Tools', count: 90, href: '/calculators/dev', color: 'text-blue-700', bg: 'bg-blue-100 border-blue-200', desc: 'JSON, Regex, Color, Base64 & more' },
              { icon: '😄', label: 'Fun Tools', count: 30, href: '/calculators/fun', color: 'text-purple-700', bg: 'bg-purple-100 border-purple-200', desc: 'Zodiac, Love, Names, Trivia & more' },
            ].map((cat, i) => (
              <Link key={i} href={cat.href} className={`flex flex-col p-4 rounded-2xl border ${cat.bg} hover:shadow-md transition-all group`}>
                <div className="flex items-center justify-between mb-1">
                  <span className="text-2xl">{cat.icon}</span>
                  <span className={`text-3xl font-black ${cat.color}`}>{cat.count}</span>
                </div>
                <p className={`font-bold text-sm ${cat.color}`}>{cat.label}</p>
                <p className="text-xs text-gray-500 mt-1 leading-snug">{cat.desc}</p>
                <p className={`text-xs font-bold mt-2 ${cat.color} opacity-0 group-hover:opacity-100 transition-opacity`}>Browse all →</p>
              </Link>
            ))}
          </div>

          <div className="prose prose-sm text-gray-600 max-w-none leading-relaxed space-y-3">
            <p>
              tooltrio.com offers <strong>392 free calculators</strong> — <strong>151 finance tools</strong> covering 401(k), Roth IRA, mortgage, SIP, FIRE, and debt payoff; <strong>121 health calculators</strong> using CDC &amp; NIH formulas for BMI, calories, macros, and heart risk; <strong>90 developer tools</strong> for JSON formatting, color conversion, regex testing, and code utilities; and <strong>30 fun tools</strong> including zodiac compatibility, name generators, and personality quizzes.
            </p>
            <p>
              <strong>For USA users:</strong> 401(k) with employer match, Roth IRA, Social Security, FIRE, 529 college savings, paycheck calculator, rent vs buy, mortgage refinance, S&amp;P 500 vs bonds — all using 2026 IRS limits. <strong>For UK users:</strong> PAYE income tax, ISA, stamp duty, pension, buy-to-let. <strong>For Europe:</strong> VAT, mortgage, and FIRE Europe calculators.
            </p>
          </div>

          <div className="flex flex-wrap gap-2 mt-5">
            {['No signup required', 'No data stored', '100% free forever', 'Works offline', 'Mobile optimized', 'Updated 2026', 'US & UK & EU', 'Privacy first'].map((t, i) => (
              <span key={i} className="text-xs font-semibold px-3 py-1.5 bg-white border border-green-200 text-green-700 rounded-full shadow-sm">✅ {t}</span>
            ))}
          </div>
        </div>
      </section>


      {/* ── FAQ Section ── */}
      <section className="max-w-3xl mx-auto px-4 mb-16" aria-label="Frequently Asked Questions">
        <h2 className="text-2xl font-black font-display text-gray-900 mb-6 text-center">Frequently Asked Questions</h2>
        <div className="space-y-3">
          {faqs.map((faq, i) => (
            <div key={i} className="bg-white rounded-2xl border border-gray-100 shadow-card p-5">
              <h3 className="font-bold text-gray-900 mb-2 flex items-start gap-2">
                <CheckCircle className="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" />
                {faq.q}
              </h3>
              <p className="text-sm text-gray-600 leading-relaxed pl-6">{faq.a}</p>
            </div>
          ))}
        </div>
      </section>
    </>
  )
}
