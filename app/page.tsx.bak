        calcs={healthCalcs}
        viewAllHref="/calculators/health"
        viewAllLabel="Browse all 60"
        accentColor="red"
        initialCount={10}
      />

      {/* ── Developer Tools ── */}
      <HomeCategorySection
        title="Developer Tools"
        subtitle="60 free browser tools — JSON, YAML, SQL, Regex, Base64, UUID, Meta Tags, Docker, CSS generators & more. No login, no server."
