export default function HomePage() {
  return (
    <>
      <script type="application/ld+json" dangerouslySetInnerHTML={{ __html: JSON.stringify(homeSchema) }} />
      <script type="application/ld+json" dangerouslySetInnerHTML={{ __html: JSON.stringify(orgSchema) }} />
      <script type="application/ld+json" dangerouslySetInnerHTML={{ __html: JSON.stringify(faqSchema) }} />
      <script type="application/ld+json" dangerouslySetInnerHTML={{ __html: JSON.stringify(itemListSchema) }} />
      <script type="application/ld+json" dangerouslySetInnerHTML={{ __html: JSON.stringify(breadcrumbSchema) }} />

      {/* ── Hero ── */}
      <section className="relative overflow-hidden" aria-label="Hero">
        <div className="absolute inset-0 bg-gradient-to-b from-green-50/80 to-white pointer-events-none" />
        <div className="absolute top-0 right-0 w-96 h-96 bg-green-200/30 rounded-full blur-3xl pointer-events-none" />
        <div className="relative max-w-5xl mx-auto px-4 pt-16 pb-12 text-center">

          {/* Trust badge */}
          <div className="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-green-100 border border-green-200 text-green-700 text-sm font-bold mb-6">
            <Globe className="w-4 h-4" />
            Supports <strong>$ USD</strong> · <strong>£ GBP</strong> · <strong>€ EUR</strong> — Switch in Header
          </div>

          <h1 className="text-4xl md:text-6xl font-black font-display text-gray-900 mb-5 leading-tight">
            Free <span className="gradient-text">Finance</span> &amp;<br />Health Calculators
          </h1>
          <p className="text-lg md:text-xl text-gray-500 max-w-2xl mx-auto mb-4 leading-relaxed">
            91 free calculators for investments, loans, commodities, retirement, UK taxes, and health — with interactive charts and expert guides. No signup ever.
          </p>

          {/* ── Search Bar ── */}
          <div className="max-w-2xl mx-auto mb-6">
            <GlobalSearch className="w-full shadow-lg" />
            <p className="text-xs text-gray-400 mt-2 text-center">
              Search 171+ calculators, tools &amp; guides — try "BMI", "401k", "mortgage", "calories"
            </p>
          </div>

          {/* Region pills */}
          <div className="flex items-center justify-center gap-2 flex-wrap mb-8 text-sm">
            <span className="px-3 py-1 rounded-full bg-blue-50 border border-blue-200 text-blue-700 font-semibold">🇺🇸 401k · Roth IRA · Social Security</span>
            <span className="px-3 py-1 rounded-full bg-red-50 border border-red-200 text-red-700 font-semibold">🇬🇧 Income Tax · ISA · Stamp Duty</span>
            <span className="px-3 py-1 rounded-full bg-yellow-50 border border-yellow-200 text-yellow-700 font-semibold">🇪🇺 VAT · Mortgage · FIRE</span>
          </div>

          <div className="flex flex-col sm:flex-row gap-3 justify-center mb-10">
            <Link href="/calculators/finance"
              className="inline-flex items-center gap-2 px-7 py-3.5 bg-green-600 hover:bg-green-700 text-white font-bold rounded-2xl transition-all shadow-lg shadow-green-200 hover:shadow-green-300 hover:-translate-y-0.5">
              <Calculator className="w-4 h-4" /> Finance Calculators
            </Link>
            <Link href="/calculators/health"
              className="inline-flex items-center gap-2 px-7 py-3.5 bg-white hover:bg-gray-50 text-gray-800 font-bold rounded-2xl border border-gray-200 hover:border-gray-300 transition-all shadow-card hover:-translate-y-0.5">
              <Heart className="w-4 h-4 text-red-500" /> Health Calculators
            </Link>
            <Link href="/blog"
              className="inline-flex items-center gap-2 px-7 py-3.5 bg-white hover:bg-gray-50 text-gray-800 font-bold rounded-2xl border border-gray-200 hover:border-gray-300 transition-all shadow-card hover:-translate-y-0.5">
              <BookOpen className="w-4 h-4 text-blue-500" /> Read Our Blog
            </Link>
          </div>

          {/* Stats bar */}
          <div className="grid grid-cols-2 sm:grid-cols-4 gap-3 max-w-3xl mx-auto">
            {stats.map((s, i) => (
              <div key={i} className="bg-white rounded-2xl border border-gray-100 shadow-card px-4 py-4 text-center">
                <div className="text-2xl mb-1">{s.icon}</div>
                <div className="text-2xl font-black text-gray-900">{s.value}</div>
                <div className="text-xs font-semibold text-gray-600">{s.label}</div>
                {s.sub && <div className="text-[10px] text-gray-400 mt-0.5">{s.sub}</div>}
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* ── Why Us ── */}
